{
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "bash $CLAUDE_PROJECT_DIR/.claude/hooks/mockup-gate.sh",
            "timeout": 5
          }
        ]
      }
    ]
  },
  "permissions": {
    "defaultMode": "dontAsk",
    "allow": [
      "Bash(npm run *)",
      "Bash(npm install *)",
      "Bash(npx *)",
      "Bash(node *)",
      "Bash(find *)",
      "Bash(grep *)",
      "Bash(rg *)",
      "Bash(ls *)",
      "Bash(jq *)",
      "Bash(which *)",
      "Bash(git status*)",
      "Bash(git log *)",
      "Bash(git diff *)",
      "Bash(git add *)",
      "Bash(git commit *)",
      "Bash(git push *)",
      "Bash(git fetch *)",
      "Bash(git checkout *)",
      "Bash(git branch *)",
      "Bash(git rebase *)",
      "Bash(git stash *)",
      "Bash(git merge *)",
      "Bash(git show *)",
      "Bash(git worktree *)",
      "Bash(gh pr *)",
      "Bash(gh api *)",
      "Bash(gh repo *)",
      "Bash(gh auth *)",
      "mcp__plugin_posthog_posthog__exec",
      "Read",
      "Glob",
      "Grep",
      "Write",
      "mcp__ccd_session__spawn_task",
      "mcp__scheduled-tasks__list_scheduled_tasks",
      "mcp__scheduled-tasks__update_scheduled_task",
      "mcp__scheduled-tasks__create_scheduled_task",
      "mcp__scheduled-tasks__delete_scheduled_task"
    ]
  }
}
