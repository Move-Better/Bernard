{
  "regions": ["pdx1"],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "X-Content-Type-Options", "value": "nosniff" },
        { "key": "X-Frame-Options", "value": "DENY" },
        { "key": "Strict-Transport-Security", "value": "max-age=31536000; includeSubDomains; preload" },
        { "key": "Referrer-Policy", "value": "strict-origin-when-cross-origin" },
        { "key": "X-XSS-Protection", "value": "0" }
      ]
    },
    {
      "source": "/",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=0, must-revalidate" }
      ]
    },
    {
      "source": "/index.html",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=0, must-revalidate" }
      ]
    },
    {
      "source": "/version.json",
      "headers": [
        { "key": "Cache-Control", "value": "no-store, max-age=0, must-revalidate" }
      ]
    },
    {
      "source": "/release-notes.json",
      "headers": [
        { "key": "Cache-Control", "value": "no-store, max-age=0, must-revalidate" }
      ]
    }
  ],
  "redirects": [
    { "source": "/status", "destination": "https://stats.uptimerobot.com/GfIsrmmYYJ", "permanent": false }
  ],
  "rewrites": [
    { "source": "/api/((?!media/(?!multipart/)[^/]+/).*)", "destination": "/api/index" },
    { "source": "/((?!api/).*)", "destination": "/index.html" }
  ],
  "crons": [
    { "path": "/api/cron/backup-db", "schedule": "0 8 * * *" },
    { "path": "/api/cron/refresh-engagement", "schedule": "0 11 * * *" },
    { "path": "/api/cron/sync-author-corpus", "schedule": "0 6 * * 0" },
    { "path": "/api/cron/regenerate-stale-books", "schedule": "0 7 * * *" },
    { "path": "/api/cron/engagement-digest", "schedule": "0 13 * * 5" },
    { "path": "/api/cron/auto-publish", "schedule": "*/10 * * * *" },
    { "path": "/api/cron/resume-longform-renders", "schedule": "*/5 * * * *" },
    { "path": "/api/cron/sync-buffer-published", "schedule": "0 * * * *" },
    { "path": "/api/cron/campaign-tune", "schedule": "0 6 * * *" },
    { "path": "/api/cron/auto-detect-clips", "schedule": "5-59/10 * * * *" },
    { "path": "/api/cron/sweep-stuck-seminars", "schedule": "*/5 * * * *" },
    { "path": "/api/cron/sweep-stuck-segment-renders", "schedule": "*/5 * * * *" },
    { "path": "/api/cron/sweep-stuck-clip-exports", "schedule": "*/5 * * * *" },
    { "path": "/api/cron/sweep-stuck-transcodes", "schedule": "*/15 * * * *" },
    { "path": "/api/cron/weekly-plan", "schedule": "0 5 * * 1" },
    { "path": "/api/cron/gsc-snapshot", "schedule": "0 4 * * 1" },
    { "path": "/api/cron/detect-supersessions", "schedule": "0 5 * * 0" },
    { "path": "/api/cron/probe-citations", "schedule": "0 6 * * 1" },
    { "path": "/api/cron/agent-tick", "schedule": "*/5 * * * *" },
    { "path": "/api/cron/check-channel-health", "schedule": "0 14 * * *" },
    { "path": "/api/cron/auto-reel-week", "schedule": "20 * * * *" },
    { "path": "/api/cron/snapshot-social-posts", "schedule": "30 5 * * 0" }
  ],
  "functions": {
    "api/media/upload.js": {
      "includeFiles": "node_modules/ffmpeg-static/**"
    },
    "api/media/tag.js": {
      "includeFiles": "node_modules/ffmpeg-static/**"
    },
    "api/media/[id]/thumbnail.js": {
      "includeFiles": "node_modules/ffmpeg-static/**"
    },
    "api/media/[id]/edit.js": {
      "includeFiles": "node_modules/ffmpeg-static/**"
    },
    "api/media/backfill-thumbnails.js": {
      "includeFiles": "node_modules/ffmpeg-static/**"
    },
    "api/editorial/render-longform.js": {
      "includeFiles": "node_modules/ffmpeg-static/**"
    },
    "api/editorial/render-longform-worker.js": {
      "includeFiles": "node_modules/ffmpeg-static/**"
    }
  }
}
